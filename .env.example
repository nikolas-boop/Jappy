# ============================================
# Jappy - Jarnos Spiel im Handy - Environment Configuration
# ============================================

# FRONTEND
# --------
VITE_API_URL=http://localhost:3001/api

# BACKEND
# -------
NODE_ENV=development
PORT=3001

# DATABASE
# --------
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_NAME=jappy
DB_PORT=3306
DB_DIALECT=mysql

# SESSION / AUTH
# ---------------
SESSION_SECRET=your_session_secret_key_change_this_in_production
SESSION_TIMEOUT=24h

# CORS
# ----
CORS_ORIGIN=http://localhost:5173

# API
# ---
API_VERSION=v1

# ENVIRONMENT
# -----------
LOG_LEVEL=debug
